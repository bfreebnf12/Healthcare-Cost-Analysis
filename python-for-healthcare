      "source": [
        "# Healthcare Cost Analysis by Demographics\n",
        "# Author: Brittany McCleod\n",
        "# Tool: Python (Pandas, Matplotlib, Seaborn)\n",
        "\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Load the dataset\n",
        "url = \"https://raw.githubusercontent.com/bfreebnf12/Healthcare-Cost-Analysis/main/insurance.csv\"\n",
        "df = pd.read_csv(url)\n",
        "\n",
        "# Preview the data\n",
        "print(\"Dataset Shape:\", df.shape)\n",
        "print(\"\\nFirst 5 rows:\")\n",
        "df.head()\n",
        "\n",
        "\n",
        "# Set visual style\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
        "fig.suptitle('Healthcare Cost Analysis by Demographics', fontsize=16, fontweight='bold')\n",
        "\n",
        "# Chart 1: Avg Charges by Region\n",
        "region_avg = df.groupby('region')['charges'].mean().sort_values(ascending=False)\n",
        "axes[0].bar(region_avg.index, region_avg.values, color=['#2196F3','#FF9800','#4CAF50','#9C27B0'])\n",
        "axes[0].set_title('Avg Charges by Region')\n",
        "axes[0].set_xlabel('Region')\n",
        "axes[0].set_ylabel('Avg Charges ($)')\n",
        "\n",
        "# Chart 2: Avg Charges by Smoker Status\n",
        "smoker_avg = df.groupby('smoker')['charges'].mean()\n",
        "axes[1].bar(smoker_avg.index, smoker_avg.values, color=['#4CAF50','#F44336'])\n",
        "axes[1].set_title('Avg Charges by Smoker Status')\n",
        "axes[1].set_xlabel('Smoker')\n",
        "axes[1].set_ylabel('Avg Charges ($)')\n",
        "\n",
        "# Chart 3: Charges by Age\n",
        "axes[2].scatter(df['age'], df['charges'], alpha=0.4, color='#2196F3')\n",
        "axes[2].set_title('Charges vs Age')\n",
        "axes[2].set_xlabel('Age')\n",
        "axes[2].set_ylabel('Charges ($)')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('healthcare_analysis.png')\n",
        "plt.show()"
      ]
    }
